---
interface Item {
  label: string;
  value: string;
}
interface Props {
  info: Item[];
  heading?: string;
  mapEmbed?: string;
}
const { info, heading, mapEmbed } = Astro.props;
---

{
  info.length > 0 && (
    <section class="info-card vellum">
      <div>
        <div class="info-card__head">
          <span class="eyebrow">The Details</span>
          {heading && <h3>{heading}</h3>}
        </div>
        <dl class="info-list">
          {info.map((i) => (
            <div>
              <dt>{i.label}</dt>
              <dd set:html={i.value} />
            </div>
          ))}
        </dl>
      </div>
      <div class="info-card__map">
        {mapEmbed ? (
          <iframe
            src={mapEmbed}
            title={`Map of ${heading ?? "the location"}`}
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            style="width:100%;height:100%;min-height:14rem;border:0;border-radius:var(--radius)"
          />
        ) : (
          "Map"
        )}
      </div>
    </section>
  )
}
