---
interface Item {
  label: string;
  value: string;
}
interface Props {
  info: Item[];
  heading?: string;
  mapEmbed?: string;
}
const { info, heading, mapEmbed } = Astro.props;

/* `mapEmbed` may be the bare Google Maps `src` URL or the whole <iframe> embed
   snippet. Pull out the URL and decode the HTML entities Google's "Copy HTML"
   leaves in it (e.g. an apostrophe in a place name becomes `&#39;`, which
   otherwise corrupts the `pb` parameter and makes Maps reject the request). */
function mapSrc(raw: string): string {
  const match = raw.match(/src=["']([^"']+)["']/i);
  let url = (match ? match[1] : raw).trim();
  url = url
    .replace(/&amp;/g, "&")
    .replace(/&#0*39;/g, "'")
    .replace(/&apos;/g, "'")
    .replace(/&#0*34;/g, '"')
    .replace(/&quot;/g, '"');
  return url;
}
const mapUrl = mapEmbed ? mapSrc(mapEmbed) : undefined;
---

{
  info.length > 0 && (
    <section class="info-card vellum">
      <div>
        <div class="info-card__head">
          <span class="eyebrow">The Details</span>
          {heading && <h3>{heading}</h3>}
        </div>
        <dl class="info-list">
          {info.map((i) => (
            <div>
              <dt>{i.label}</dt>
              <dd set:html={i.value} />
            </div>
          ))}
        </dl>
      </div>
      <div class="info-card__map">
        {mapUrl ? (
          <iframe
            src={mapUrl}
            title={`Map of ${heading ?? "the location"}`}
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            style="width:100%;height:100%;min-height:14rem;border:0;border-radius:var(--radius)"
          />
        ) : (
          "Map"
        )}
      </div>
    </section>
  )
}
