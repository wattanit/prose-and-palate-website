---
/* A body section for the review layouts. Single full-width column by default:
   paragraphs and figures stack in source order. To place blocks side by side,
   wrap them in a <Row> inside the section.
   - default : full-width column
   - prose   : narrowed to a comfortable reading measure */
interface Props {
  heading?: string;
  id?: string;
  variant?: "default" | "prose";
}
const { heading, id, variant = "default" } = Astro.props;
const cls = variant === "prose" ? "section section--prose" : "section";
---

<section class={cls} id={id}>
  {heading && <h2>{heading}</h2>}
  <slot />
</section>
