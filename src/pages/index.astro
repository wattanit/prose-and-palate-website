---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllReviews,
  getReviews,
  CATEGORY,
  reviewHref,
  collectionOf,
  type ReviewEntry,
} from "@/lib/reviews";
import { formatShort, readingTime } from "@/lib/format";

const [all, bars, drinks, books] = await Promise.all([
  getAllReviews(),
  getReviews("bars"),
  getReviews("drinks"),
  getReviews("books"),
]);

const cover = bars[0] ?? all[0];
const rest = all.filter((e) => e !== cover);
const lead = rest[0];
const compact = rest.slice(1, 5);

function info(entry: ReviewEntry) {
  const d = entry.data;
  const cat = CATEGORY[collectionOf(entry)];
  return {
    href: reviewHref(entry),
    label: cat.label,
    tagClass: cat.tagClass,
    eyebrow: d.eyebrow ? `${cat.label} · ${d.eyebrow}` : cat.label,
    img: d.hero_image ?? ("cover_image" in d ? d.cover_image : undefined),
    imgPortrait: d.hero_image_portrait,
    alt: d.hero_alt ?? d.title,
    title: d.title,
    description: d.description,
    read: readingTime(entry.body ?? ""),
    date: formatShort(d.date),
    isBook: collectionOf(entry) === "books",
  };
}

const coverInfo = cover ? info(cover) : null;
const leadInfo = lead ? info(lead) : null;

const booksData = books[0]?.data;
const booksImg =
  booksData && "cover_image" in booksData
    ? booksData.cover_image
    : "/images/site/book-cover.svg";

const explore = [
  {
    href: "/bars",
    label: "Bars",
    tagClass: "tag--bars",
    title: "Bars & Rooms",
    blurb: CATEGORY.bars.blurb,
    cta: "Browse bars",
    img: bars[0]?.data.hero_image ?? "/images/site/home-feature-2.jpg",
    wide: true,
    isBook: false,
  },
  {
    href: "/drinks",
    label: "Drinks",
    tagClass: "tag--drinks",
    title: "Drinks & Spirits",
    blurb: CATEGORY.drinks.blurb,
    cta: "Browse drinks",
    img: drinks[0]?.data.hero_image ?? "/images/site/drink-1.jpg",
    wide: false,
    isBook: false,
  },
  {
    href: "/books",
    label: "Books",
    tagClass: "tag--books",
    title: "Books & Pages",
    blurb: CATEGORY.books.blurb,
    cta: "Browse books",
    img: booksImg,
    wide: false,
    isBook: true,
  },
];
---

<BaseLayout>
  <main>
    {
      coverInfo && (
        <div class="container">
          <section class="cover">
            <div
              class={`cover__img${coverInfo.imgPortrait ? " cover__img--wide" : ""}`}
              style={`background-image:url('${coverInfo.img}')`}
              role="img"
              aria-label={coverInfo.alt}
            />
            {coverInfo.imgPortrait && (
              <div
                class="cover__img cover__img--portrait"
                style={`background-image:url('${coverInfo.imgPortrait}')`}
                role="img"
                aria-label={coverInfo.alt}
              />
            )}
            <div class="cover__scrim" />
            <div class="cover__content">
              <div class="inner">
                <span class="eyebrow">The Cover Story</span>
                <h1>
                  <a href={coverInfo.href} style="color:inherit"
                    >{coverInfo.title}</a
                  >
                </h1>
                {coverInfo.description && (
                  <p class="lede">{coverInfo.description}</p>
                )}
                <div class="meta">
                  <strong>{coverInfo.eyebrow}</strong>
                  <span class="dot" />
                  <span>{coverInfo.date}</span>
                  <span class="dot" />
                  <span>{coverInfo.read}</span>
                </div>
              </div>
            </div>
          </section>
        </div>
      )
    }

    {
      leadInfo && (
        <div class="container">
          <h2 class="section-title">Latest Articles</h2>
          <section class="issue">
            <article class="issue__lead">
              <a
                href={leadInfo.href}
                class={`card__media${leadInfo.isBook ? " is-book" : ""}`}
                style={leadInfo.isBook ? `--cover:url('${leadInfo.img}')` : undefined}
              >
                <img src={leadInfo.img} alt={leadInfo.alt} />
                <span class={`tag ${leadInfo.tagClass}`}>{leadInfo.label}</span>
              </a>
              <span class="eyebrow">{leadInfo.eyebrow}</span>
              <h3 class="card__title">{leadInfo.title}</h3>
              {leadInfo.description && (
                <p class="card__excerpt">{leadInfo.description}</p>
              )}
              <div class="meta">
                <strong>{leadInfo.label}</strong>
                <span class="dot" />
                <span>{leadInfo.read}</span>
              </div>
              <p style="margin-top:1rem">
                <a href={leadInfo.href} class="read-more">
                  Read the review <span class="arrow">→</span>
                </a>
              </p>
            </article>

            <div class="issue__list">
              {compact.map((entry) => {
                const c = info(entry);
                return (
                  <a href={c.href} class="issue__entry">
                    <div
                      class={`card__media${c.isBook ? " is-book" : ""}`}
                      style={c.isBook ? `--cover:url('${c.img}')` : undefined}
                    >
                      <img src={c.img} alt={c.alt} />
                    </div>
                    <div class="issue__entry-body">
                      <span class="eyebrow">{c.eyebrow}</span>
                      <h4 class="card__title">{c.title}</h4>
                      {c.description && (
                        <p class="card__excerpt">{c.description}</p>
                      )}
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        </div>
      )
    }

    <div class="container">
      <h2 class="section-title">Explore by Subject</h2>
      <section class="reviews" style="margin-top:0">
        {
          explore.map((e) => (
            <a href={e.href} class={e.wide ? "card card--wide" : "card"}>
              <div
                class={`card__media${e.isBook ? " is-book" : ""}`}
                style={e.isBook ? `--cover:url('${e.img}')` : undefined}
              >
                <img src={e.img} alt={e.title} />
                <span class={`tag ${e.tagClass}`}>{e.label}</span>
              </div>
              <h3 class="card__title">{e.title}</h3>
              <p class="card__excerpt">{e.blurb}</p>
              <span class="read-more">
                {e.cta} <span class="arrow">→</span>
              </span>
            </a>
          ))
        }
      </section>
    </div>

    <div class="container">
      <section class="statement">
        <span class="eyebrow">The Editorial</span>
        <p>
          A good bar, a good drink, a good book — each is just a room with the
          lights turned low, waiting for you to sit down and stay.
        </p>
        <div class="sig">— The Editors, Prose &amp; Palate</div>
      </section>
    </div>
  </main>
</BaseLayout>
