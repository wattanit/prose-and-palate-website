---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <main class="container">
    <article class="std-article">
      <header class="std-article__head">
        <span class="eyebrow">404</span>
        <h1>Lost the thread.</h1>
        <p class="lede">
          The page you’re looking for has wandered off — perhaps to a quiet bar
          somewhere, nursing something brown.
        </p>
      </header>
      <p style="text-align:center; margin-top:1rem">
        <a href="/" class="btn">Back to the magazine <span class="arrow">→</span></a>
      </p>
    </article>
  </main>
</BaseLayout>
